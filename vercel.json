{
  "version": 2,
  "builds": [
    {
      "src": "api/download.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "api/status.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 10
      }
    },
    {
      "src": "api/file.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/download",
      "dest": "/api/download.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/status/(?<id>[^/]+)",
      "dest": "/api/status.js?id=$id"
    },
    {
      "src": "/api/file/(?<id>[^/]+)",
      "dest": "/api/file.js?id=$id"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ]
}
