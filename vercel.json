{
  "version": 2,
  "builds": [
    {
      "src": "api/download.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/download",
      "dest": "/api/download.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ]
}
