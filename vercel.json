{
  "version": 2,
  "builds": [
    {
      "src": "api/download.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/status.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/file.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "functions": {
    "api/download.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/download",
      "dest": "/api/download.js"
    },
    {
      "src": "/api/status/(?<id>[^/]+)",
      "dest": "/api/status.js?id=$id"
    },
    {
      "src": "/api/file/(?<id>[^/]+)",
      "dest": "/api/file.js?id=$id"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ]
}
